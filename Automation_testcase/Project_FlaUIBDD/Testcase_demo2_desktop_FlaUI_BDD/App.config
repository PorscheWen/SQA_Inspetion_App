<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- 相對路徑以 SQA_Inspetion_App 根目錄（含 config.json）為基準；亦可由環境變數覆寫 -->
    <add key="ApplicationPath" value="SemiInspectionDesktop\bin\Debug\SemiInspectionDesktop.exe" />
    <add key="ApplicationTitle" value="Semi Inspection Desktop" />
    <add key="ProcessName" value="SemiInspectionDesktop" />
    <add key="RecipeDataDirectory" value="Recipe_data" />
    <add key="SampleRecipe" value="InspectionRecipe_Sample.json" />
    <add key="ImportTargetFile" value="TC01_import_copy.json" />
    <add key="InvalidSampleFile" value="_invalid_sample.txt" />
    <add key="DefaultTimeout" value="30000" />
    <add key="ElementTimeout" value="10000" />
    <add key="TakeScreenshotOnFailure" value="true" />
    <add key="TakeScreenshotOnClick" value="true" />
    <add key="TakeScreenshotOnScenarioEnd" value="true" />
    <add key="ScreenshotDirectory" value="Screenshots" />
    <add key="WriteFailureLogOnFailure" value="true" />
    <add key="FailureLogDirectory" value="FailureLogs" />
  </appSettings>
</configuration>
